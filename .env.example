# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Document Authoring Configuration
DA_ORG=carlossg
DA_REPO=arco

# DA Authentication (S2S - preferred)
DA_CLIENT_ID=
DA_CLIENT_SECRET=
DA_SERVICE_TOKEN=

# DA Authentication (Legacy fallback)
DA_TOKEN=

# Model Configuration
MODEL_PRESET=production

# Feature Flags
# LLM-generated hero copy (set to "false" to use deterministic copy)
LLM_HERO_COPY=true

# Optional: Vertex AI Endpoint for Gemma (requires GPU deployment)
GEMMA_ENDPOINT_ID=
